<xs:include schemaLocation="papiNetCommonDefsV2R40.xsd"/>
	<xs:element name="CreditDebitNote">
		<xs:annotation>
			<xs:documentation>CreditDebitNote e-Document will be deprecated in a future version V3R00 and should not be used in new implementations. Use instead Invoice e-Document with attribute InvoiceType having enumerations CreditNote or DebitNote. </xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="CreditDebitNoteHeader"/>
				<xs:element ref="CreditDebitNoteLineItem" maxOccurs="unbounded"/>
				<xs:element ref="MonetaryAdjustment" minOccurs="0" maxOccurs="unbounded"/>
				<xs:element ref="CreditDebitNoteSummary"/>
			</xs:sequence>
			<xs:attribute name="CreditDebitNoteType" type="creditDebitNoteType" use="required"/>
			<xs:attribute name="Reissued" type="yesNo" default="No"/>
			<xs:attribute name="Language" type="languageType" default="eng"/>
		</xs:complexType>
	</xs:element>
</xs:schema>










